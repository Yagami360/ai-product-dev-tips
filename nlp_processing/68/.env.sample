# このファイルを .env にコピーして使う（cp .env.sample .env）。
# Makefile が .env を読み込み、コンテナへ環境変数として渡す。

# HuggingFace アクセストークン（任意）
#   - 1EE1 / amazon/chronos-t5-base / TinyLlama 等の公開モデルのみなら未設定でよい。
#   - gated モデル（例: meta-llama 系を base LLM に使う場合）や、匿名 rate limit の
#     回避が必要な場合に設定する。 https://huggingface.co/settings/tokens で発行。
HF_TOKEN=

# 使用するモデル/データ（既定のままで動く。変更したいときだけ上書き）
HF_REPO=1EE1/SensorLLM-Stage1-Backup
CHRONOS_REPO=amazon/chronos-t5-base
DATASET=mhealth

# HF Xet が 403/503 で不調なとき 1 にする（認証済み LFS-bridge=cas-bridge 経路を強制）
HF_HUB_DISABLE_XET=1
