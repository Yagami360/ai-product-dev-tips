.env

# 公式リポジトリ（README の手順で clone する外部リポジトリ。この Tip では管理しない）
SensorLLM/

# uv 仮想環境
.venv/

# 大容量の DL 物・学習済み ckpt・データセット・出力（いずれも再生成可能なので git 管理外）
