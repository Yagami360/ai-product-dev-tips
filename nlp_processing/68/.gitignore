#   datasets/    … MHealth 生データ + 学習用に生成した pkl/QA
#   outputs/     … 推論サンプル(.npy)・結果(.npz)・plots/
checkpoints/
datasets/
outputs/
*.part

# Python キャッシュ
__pycache__/
*.pyc
mHealth*.log
*.npy
*.npz

