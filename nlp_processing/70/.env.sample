# このファイルを .env にコピーして値を設定する（.env は git 管理外）。
#   cp .env.sample .env

# 説明層 LLM（OpenAI 互換エンドポイント）の API キー。
# 既定は Google Gemini。https://aistudio.google.com/apikey で取得したキーを設定する。
OPENAI_API_KEY=your-api-key-here

# 使う LLM / エンドポイントを変えるとき（未設定なら Makefile の既定 = Gemini 3.5 Flash）
# BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_MODEL=gemini-3.5-flash
# REASONING_EFFORT=low

# ローカル完結（GPU/APIキー不要）にするなら Ollama:
#   ollama serve && ollama pull qwen3:4b
# BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen3:4b
# REASONING_EFFORT=
